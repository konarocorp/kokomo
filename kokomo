def calc_guide_position(*, guides, index, length, margin):
    guides = eva.normalize_integer(guides, minimum=2)
    length = eva.normalize_integer(length, minimum=1)
    margin = eva.normalize_integer(margin, minimum=0)
    index  = eva.normalize_float(index, maximum=guides, minimum=1)

    windows  = guides - 1
    free     = length - (guides * margin)
    step     = margin + (free / windows)
    position = step * (index - 1)
    position = position + 1

    return position




def calc_positions_and_sizes(*, height, width):
    height   = eva.normalize_integer(height, minimum=0)
    width    = eva.normalize_integer(width, minimum=0)
    snapshot = SNAPSHOT
    margin   = M.math.sqrt(height * width) / 100 * MARGIN_PERCENTAGE
    margin   = eva.normalize_integer(margin, minimum=0)

    if height < 11: # 11 -> h1 + smoothed + h2 + load + h3 + minimum + h4 + current + h5 + maximum + h6
        margin = 0

    h0 = GUIDES.h0
    h1 = GUIDES.h1
    h2 = GUIDES.h2
    h3 = GUIDES.h3
    h4 = GUIDES.h4
    h5 = GUIDES.h5
    h6 = GUIDES.h6

    v1 = GUIDES.v1
    v2 = GUIDES.v2
    v3 = GUIDES.v3

    cpus      = WINDOWS.cpus
    current   = WINDOWS.current
    histogram = WINDOWS.histogram
    load      = WINDOWS.load
    maximum   = WINDOWS.maximum
    minimum   = WINDOWS.minimum
    smoothed  = WINDOWS.smoothed

    v1.height = height
    v1.width  = margin
    v1.x      = 1
    v1.y      = 1

    v2.height = height
    v2.width  = margin
    v2.x      = calc_guide_position(index=2.333, length=width, margin=margin, guides=3)
    v2.y      = 1

    v3.height = height
    v3.width  = margin
    v3.x      = calc_guide_position(index=3, length=width, margin=margin, guides=3)
    v3.y      = 1

    h1.height = margin
    h1.width  = width
    h1.x      = 1
    h1.y      = 1

    h2.height = margin
    h2.width  = (v3.x + v3.width) - v2.x
    h2.x      = v2.x
    h2.y      = calc_guide_position(index=2, length=height, margin=margin, guides=6)

    h3.height = margin
    h3.width  = h2.width
    h3.x      = h2.x
    h3.y      = calc_guide_position(index=3, length=height, margin=margin, guides=6)

    h4.height = margin
    h4.width  = h2.width
    h4.x      = h2.x
    h4.y      = calc_guide_position(index=4, length=height, margin=margin, guides=6)

    h5.height = margin
    h5.width  = h2.width
    h5.x      = h2.x
    h5.y      = calc_guide_position(index=5, length=height, margin=margin, guides=6)

    h6.height = margin
    h6.width  = width
    h6.x      = 1
    h6.y      = calc_guide_position(index=6, length=height, margin=margin, guides=6)

    h0.height   = margin
    h0.width    = (v2.x + v2.width) - v1.x
    h0.x        = 1
    h0.y        = calc_guide_position(index=2, length=height, margin=margin, guides=3)
    cpus.height = len(snapshot.cpus) + (3 if cpus.border else 1) # 3 -> border + header + border, 1 -> header
    h0.y        = min(h0.y, cpus.height + h1.height + h1.y)

    if margin:
        v1.width += margin
        v2.width += margin
        v3.x     -= margin
        v3.width += margin

    cpus.height = h0.y - h1.y - h1.height
    cpus.width  = v2.x - v1.x - v1.width
    cpus.x      = v1.x + v1.width
    cpus.y      = h1.y + h1.height

    histogram.height = h6.y - h0.y - h0.height
    histogram.width  = cpus.width
    histogram.x      = cpus.x
    histogram.y      = h0.y + h0.height

    smoothed.height = h2.y - h1.y - h1.height
    smoothed.width  = v3.x - v2.x - v2.width
    smoothed.x      = v2.x + v2.width
    smoothed.y      = h1.y + h1.height

    load.height = h3.y - h2.y - h2.height
    load.width  = smoothed.width
    load.x      = smoothed.x
    load.y      = h2.y + h2.height

    minimum.height = h4.y - h3.y - h3.height
    minimum.width  = smoothed.width
    minimum.x      = smoothed.x
    minimum.y      = h3.y + h3.height

    current.height = h5.y - h4.y - h4.height
    current.width  = smoothed.width
    current.x      = smoothed.x
    current.y      = h4.y + h4.height

    maximum.height = h6.y - h5.y - h5.height
    maximum.width  = smoothed.width
    maximum.x      = smoothed.x
    maximum.y      = h5.y + h5.height




def main():
    global ANSI, EVENTS, FAHRENHEIT, FONTS, GLYPHS, GUIDES, STRESS, WINDOWS, ZONES

    if arguments := parse_arguments():
        FAHRENHEIT = arguments.fahrenheit
        STRESS     = arguments.stress

        if arguments.help:
            show_usage_and_exit(error=False)
    else:
        show_usage_and_exit(error=True)

    M.signal.signal(M.signal.SIGINT,   signal_handler_graceful_exit)
    M.signal.signal(M.signal.SIGTERM,  signal_handler_graceful_exit)
    M.signal.signal(M.signal.SIGWINCH, signal_handler_window_resized)

    ANSI    = build_ansi()
    EVENTS  = build_events()
    FONTS   = build_fonts()
    GLYPHS  = build_glyphs()
    ZONES   = build_zones()

    GUIDES  = build_guides()
    WINDOWS = build_windows()

    keyboard = M.threading.Thread(daemon=True, target=target_keyboard)
    mouse    = M.threading.Thread(daemon=True, target=target_mouse)
    screen   = M.threading.Thread(daemon=True, target=target_screen)
    snapshot = M.threading.Thread(daemon=True, target=target_snapshot)
    stress   = M.threading.Thread(daemon=True, target=target_stress)
    threads  = (snapshot,) + (keyboard, mouse, stress) + (screen,)

    try:
        TERMINAL.save_cursor()
        TERMINAL.enable_alt_screen()
        TERMINAL.clear_screen()
        TERMINAL.disable_cursor()
        TERMINAL.move_home()

        for thread in threads:
            thread.start()

        EVENTS.bye.wait()

        for event in vars(EVENTS).values():
            event.set()

        for thread in threads:
            thread.join()
    finally:
        TERMINAL.enable_cursor()
        TERMINAL.clear_screen()
        TERMINAL.disable_alt_screen()
        TERMINAL.restore_cursor()




def parse_arguments():
    def argparse_error_handler(message='', /):
        raise M.argparse.ArgumentError(None, message)

    parser       = M.argparse.ArgumentParser(add_help=False, allow_abbrev=False, exit_on_error=False)
    parser.error = argparse_error_handler

    parser.add_argument('-f', '--fahrenheit', action='count', default=0)
    parser.add_argument('-h', '--help',       action='count', default=0)
    parser.add_argument('-s', '--stress',     action='count', default=0)

    try:
        arguments = parser.parse_args()

        if any( argument > 1 for argument in vars(arguments).values() ):
            argparse_error_handler()

        ret            = M.types.SimpleNamespace()
        ret.fahrenheit = bool(arguments.fahrenheit)
        ret.help       = bool(arguments.help)
        ret.stress     = bool(arguments.stress)
    except M.argparse.ArgumentError:
        ret = False

    return ret




def precompile_frequency(value, /, *, compact=False, ghz=False):
    compact   = bool(compact)
    fstr      = '{align}{affix}'
    ghz       = bool(ghz)
    affix     = 'GHz' if ghz else 'MHz'
    divisor   = 1000 if ghz else 1
    maximum   = 9.9 if ghz else 9999.0
    minimum   = 0.0
    padding   = 3 if ghz else 4
    precision = 1 if ghz else 0
    space     = ' '
    value     = maximum if value is None else float(value)
    value     = value / divisor
    string    = eva.normalize_float(value, maximum=maximum, minimum=minimum, padding=True, precision=precision)

    if compact:
        affix = affix[0]

    ret         = M.types.SimpleNamespace()
    ret.affix   = affix
    ret.align   = string.rjust(padding, space)
    ret.full    = fstr.format(affix=affix, align=ret.align)
    ret.compact = ret.full.strip(space)
    ret.string  = string
    ret.value   = float(string)

    return ret




def precompile_load(value, /, *, integer=False):
    affix     = '%'
    fstr      = '{align}{affix}'
    integer   = bool(integer)
    maximum   = 100.0
    minimum   = 0.0
    padding   = 3 if integer else 4
    precision = 0 if integer else 1
    space     = ' '
    value     = maximum if value is None else float(value)
    string    = eva.normalize_float(value, maximum=maximum, minimum=minimum, padding=True, precision=precision)
    value     = float(string)

    if value >= 100:
        precision = 0
        string    = eva.normalize_float(value, maximum=maximum, minimum=minimum, padding=True, precision=precision)
        value     = float(string)

    ret         = M.types.SimpleNamespace()
    ret.affix   = affix
    ret.align   = string.rjust(padding, space)
    ret.color   = select_color_by_load(value)
    ret.full    = fstr.format(affix=affix, align=ret.align)
    ret.compact = ret.full.strip(space)
    ret.string  = string
    ret.value   = value

    return ret




def precompile_temperature(value, /, *, integer=False):
    affix     = '°F' if FAHRENHEIT else '°C'
    fstr      = '{align}{affix}'
    integer   = bool(integer)
    maximum   = TEMPERATURE_MAXIMUM
    minimum   = TEMPERATURE_MINIMUM
    padding   = 3 if FAHRENHEIT or integer else 4
    precision = 0 if FAHRENHEIT or integer else 1
    space     = ' '
    value     = maximum if value is None else float(value)

    if value >= 100:
        precision = 0

    string  = eva.normalize_float(value, maximum=maximum, minimum=minimum, padding=True, precision=precision)
    celsius = float(string)

    if FAHRENHEIT:
        value  = (value * 1.8) + 32
        string = eva.normalize_float(value, maximum=maximum, minimum=minimum, padding=True, precision=precision)

    ret         = M.types.SimpleNamespace()
    ret.affix   = affix
    ret.align   = string.rjust(padding, space)
    ret.celsius = celsius
    ret.color   = select_color_by_temperature(celsius)
    ret.full    = fstr.format(affix=affix, align=ret.align)
    ret.compact = ret.full.strip(space)
    ret.string  = string
    ret.value   = float(string)

    return ret




def precompile_thread(value, /):
    affix     = 'CPU'
    fstr      = '{affix}{align}'
    maximum   = CPU_HIGHEST_THREAD
    minimum   = 0
    value     = maximum if value is None else eva.clamp(value, minimum, maximum)
    padding   = len(str(maximum))
    space     = ' '
    string    = str(value)

    ret         = M.types.SimpleNamespace()
    ret.affix   = affix
    ret.align   = string.ljust(padding, space)
    ret.full    = fstr.format(affix=affix, align=ret.align)
    ret.compact = ret.full.strip(space)
    ret.string  = string
    ret.value   = value

    return ret




