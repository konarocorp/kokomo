class CPUs(Window):
    _arrow_both    = '↕'
    _arrow_down    = '↓'
    _arrow_up      = '↑'
    _default_focus = 'thread'


    def __init__(self, *args, **kwargs):
        super().__init__(*args, **kwargs)

        self._fields       = M.collections.deque(CPU_LAYOUT_FIELDS)
        self._fingerprint  = None
        self._layout       = False
        self._reverse      = False
        self._scroll_index = 0
        self._viewport     = 0


    def _calc_layout(self, /, *, cpus):
        by_length   = lambda layout: layout.length.minimum
        cls         = self.__class__
        arrow       = cls._arrow_both
        copy        = lambda sn: M.types.SimpleNamespace(**vars(sn))
        cpus        = eva.normalize_integer(cpus, minimum=1)
        empty       = ''
        fingerprint = M.types.SimpleNamespace()
        fstr        = '{thread} {temperature} {load} {minscal} {frequency} {maxscal}{sep1}{bar}{sep2}{scroll}'
        space       = ' '

        with self._instance_lock:
            size     = self.inner
            viewport = min(cpus, size.height - 1) # 1 -> header
            overflow = cpus > viewport

            self._scroll_index = eva.clamp(self._scroll_index, 0, cpus - viewport)
            self._viewport     = viewport

            fingerprint.cpus   = cpus
            fingerprint.height = size.height
            fingerprint.width  = size.width

            if self._fingerprint == fingerprint:
                return self._layout
            else:
                self._fingerprint = fingerprint
                self._layout      = False

            if not viewport:
                return

            dummy             = M.types.SimpleNamespace()
            dummy.bar         = empty
            dummy.frequency   = None
            dummy.load        = None
            dummy.scroll      = arrow if overflow else empty
            dummy.sep1        = empty
            dummy.sep2        = space if overflow else empty
            dummy.temperature = None
            dummy.thread      = None

            # CPU0 99.9°C 99.9% 1234MHz 1234MHz 1234MHz
            full          = M.types.SimpleNamespace()
            full.compact  = False
            full.fstr     = fstr
            full.ghz      = False
            full.integer  = False
            full.overflow = overflow

            # CPU0 99.9°C 99.9% 1234M 1234M 1234M
            compact         = copy(full)
            compact.compact = True

            # CPU0 100°C 100% 1234M 1234M 1234M
            integer         = copy(compact)
            integer.integer = True

            # CPU0 100°C 100% 9.9G 9.9G 9.9G
            ghz     = copy(integer)
            ghz.ghz = True

            layouts = (full, compact, integer, ghz)

            for layout in layouts:
                frequency     = precompile_frequency(dummy.frequency, ghz=layout.ghz, compact=layout.compact).full
                layout.length = M.types.SimpleNamespace()

                kwargs                = dict()
                kwargs['bar']         = dummy.bar
                kwargs['frequency']   = frequency
                kwargs['load']        = precompile_load(dummy.load, integer=layout.integer).full
                kwargs['maxscal']     = frequency
                kwargs['minscal']     = frequency
                kwargs['scroll']      = dummy.scroll
                kwargs['sep1']        = dummy.sep1
                kwargs['sep2']        = dummy.sep2
                kwargs['temperature'] = precompile_temperature(dummy.temperature, integer=layout.integer).full
                kwargs['thread']      = precompile_thread(dummy.thread).full

                for key, value in kwargs.items():
                    setattr(layout.length, key, len(value))

                layout.length.minimum = len(layout.fstr.format(**kwargs))
                layout.length.bar     = max(size.width - layout.length.minimum, 0)

                if layout.length.bar:
                    layout.length.bar  = layout.length.bar - 1 # 1 -> sep1
                    layout.length.sep1 = 1

            layouts = sorted(layouts, key=by_length, reverse=True)

            for layout in layouts:
                if layout.length.minimum <= size.width:
                    self._layout = layout
                    break


    def _render(self, /, *, height, width):
        by_field   = lambda cpu: getattr(cpu, focus)
        cls        = self.__class__
        default    = ANSI.default
        empty      = ''
        output     = []
        mask_down  = 0b01
        mask_empty = 0b00
        mask_up    = 0b10
        mask_both  = mask_down | mask_up
        space      = ' '

        arrows = {
            mask_both:  cls._arrow_both,
            mask_down:  cls._arrow_down,
            mask_empty: space,
            mask_up:    cls._arrow_up,
        }

        has_overflow_above = lambda y: y == 0 and index > 0
        has_overflow_below = lambda y: y == len(samples) - 1 and index < len(cpus) - len(samples)

        with self._instance_lock:
            cpus = SNAPSHOT.cpus

            self._calc_layout(cpus=len(cpus))

            focus    = self._fields[0]
            index    = self._scroll_index
            layout   = self._layout
            reverse  = self._reverse
            samples  = cpus
            viewport = self._viewport

        if not layout:
            return

        if focus != self._default_focus:
            samples = sorted(samples, key=by_field, reverse=reverse)

        samples = samples[index:index + viewport]
        header  = self._subrender_header(focus=focus, layout=layout, reverse=reverse)

        output.append(header)

        for y, cpu in enumerate(samples):
            frequency   = precompile_frequency(cpu.frequency, compact=layout.compact, ghz=layout.ghz)
            load        = precompile_load(cpu.load, integer=layout.integer)
            maxscal     = precompile_frequency(cpu.maxscal, compact=layout.compact, ghz=layout.ghz)
            minscal     = precompile_frequency(cpu.minscal, compact=layout.compact, ghz=layout.ghz)
            temperature = precompile_temperature(cpu.temperature, integer=layout.integer)
            bar         = self._subrender_bar(load=load, temperature=temperature, layout=layout)
            thread      = precompile_thread(cpu.thread)

            if layout.overflow:
                bitmask = mask_empty

                if has_overflow_above(y):
                    bitmask = bitmask | mask_up

                if has_overflow_below(y):
                    bitmask = bitmask | mask_down

                scroll = arrows[bitmask]
            else:
                scroll = empty

            kwargs         = dict()
            kwargs['bar']  = bar
            kwargs['sep1'] = space * layout.length.sep1
            kwargs['sep2'] = space if layout.overflow else empty

            kwargs['frequency'] = frequency.align \
                                + ANSI.dim.on     \
                                + frequency.affix \
                                + ANSI.dim.off

            kwargs['load'] = load.color.fg.dark \
                           + load.align         \
                           + ANSI.dim.on        \
                           + load.affix         \
                           + ANSI.default.all

            kwargs['maxscal'] = maxscal.align \
                              + ANSI.dim.on   \
                              + maxscal.affix \
                              + ANSI.dim.off

            kwargs['minscal'] = minscal.align \
                              + ANSI.dim.on   \
                              + minscal.affix \
                              + ANSI.dim.off

            kwargs['scroll'] = ANSI.cyan.fg.dark \
                             + scroll            \
                             + default.fg

            kwargs['thread'] = ANSI.dim.on  \
                             + thread.affix \
                             + ANSI.dim.off \
                             + thread.align

            kwargs['temperature'] = temperature.color.fg.dark \
                                  + temperature.align         \
                                  + ANSI.dim.on               \
                                  + temperature.affix         \
                                  + ANSI.default.all

            if focus != self._default_focus:
                kwargs[focus] = ANSI.reverse.on + kwargs[focus] + ANSI.reverse.off

            line = layout.fstr.format(**kwargs)

            output.append(line)

        return M.os.linesep.join(output)


    @staticmethod
    def _subrender_bar(*, layout, load, temperature):
        empty  = ''
        filler = '▮'
        space  = ' '

        blank_glyph_above = f'{ANSI.black.fg.light}╱{ANSI.default.fg}'
        blank_glyph_below = f'{ANSI.black.fg.light}╲{ANSI.default.fg}'
        blank_glyph_half  = f'{ANSI.black.fg.light}╳{ANSI.default.fg}'
        blank_row_above   = [blank_glyph_above] * M.math.floor(layout.length.bar / 2)
        blank_row_below   = [blank_glyph_below] * M.math.floor(layout.length.bar / 2)
        blank_row_half    = [blank_glyph_half] if layout.length.bar % 2 else []
        ret               = blank_row_above + blank_row_half + blank_row_below

        if ret:
            load_percentage        = M.math.ceil(load.value                    / 100 * layout.length.bar)
            temperature_percentage = M.math.ceil(min(temperature.celsius, 100) / 100 * layout.length.bar)

            for x in range(len(ret)):
                cell = space

                if load_percentage > x:
                    cell = f'{load.color.fg.light}{filler}{ANSI.default.fg}'

                if temperature_percentage > x:
                    cell = f'{temperature.color.bg.dark}{cell}{ANSI.default.bg}'

                if cell != space:
                    ret[x] = cell

        return empty.join(ret)


    @classmethod
    def _subrender_header(cls, /, *, focus, layout, reverse):
        glyph_default_sort = '▼'
        glyph_reverse_sort = '▲'
        empty              = ''
        focus              = str(focus)
        kwargs             = dict()
        messages_off       = ('stress test OFF', 'OFF')
        messages_on        = ('stress test ON ({minutes}m {seconds}s)', '{minutes}m {seconds}s', 'ON')
        messages_monitor   = ('monitor mode', 'monitor', 'm')
        reverse            = bool(reverse)
        select_message     = lambda m, l: max(( i for i in m if len(i) <= l), key=len, default=empty)
        space              = ' '

        for field, length in vars(layout.length).items():
            value = space * length

            if field == focus and field != cls._default_focus:
                value = glyph_reverse_sort if reverse else glyph_default_sort
                value = value.center(length, space)
                value = f'{ANSI.reverse.on}{value}{ANSI.reverse.off}'
            elif field in ('sep2', 'scroll'):
                value = empty
            elif field == 'bar':
                length = length + layout.length.sep2 + layout.length.scroll

                if not STRESS:
                    message = select_message(messages_monitor, length)
                    message = message.center(length)
                    value   = f'{ANSI.default.fg}{message}'
                elif EVENTS.stress.is_set():
                    message = select_message(messages_on, length)
                    seconds = eva.normalize_integer(STRESS_CHRONO.delta)
                    minutes = seconds // 60
                    seconds = seconds % 60
                    message = message.format(minutes=minutes, seconds=seconds)
                    message = message.center(length)
                    value   = f'{ANSI.blink.on}{ANSI.red.fg.dark}{message}{ANSI.default.fg}{ANSI.blink.off}'
                else:
                    message = select_message(messages_off, length)
                    message = message.center(length)
                    value   = f'{ANSI.yellow.fg.dark}{message}{ANSI.default.fg}'

            kwargs[field] = value

        return layout.fstr.format(**kwargs)


    def scroll_down(self, /):
        with self._instance_lock:
            self._scroll_index += 1

        self.show()


    def scroll_up(self, /):
        with self._instance_lock:
            self._scroll_index -= 1

        self.show()


    def select_left(self, /):
        with self._instance_lock:
            self._fields.rotate(1)

        self.show()


    def select_right(self, /):
        with self._instance_lock:
            self._fields.rotate(-1)

        self.show()


    def toggle_reverse(self, /):
        with self._instance_lock:
            self._reverse = not self._reverse

        self.show()




class Histogram(Window):
    def __init__(self, *args, **kwargs):
        super().__init__(*args, **kwargs)

        self._cache       = []
        self._fingerprint = None


    def _render(self, /, *, height, width):
        column      = []
        empty       = ''
        height      = eva.normalize_integer(height, minimum=self._minimum_height)
        output      = []
        snapshot    = SNAPSHOT
        load        = precompile_load(snapshot.load)
        temperature = precompile_temperature(snapshot.current)
        space       = ' '
        width       = eva.normalize_integer(width, minimum=self._minimum_width)
        fingerprint = (height, width)

        if 0 in fingerprint:
            return

        load_percentage        = M.math.ceil(load.value                    / 100 * height)
        temperature_percentage = M.math.ceil(min(temperature.celsius, 100) / 100 * height)

        blank_glyph_above  = f'{ANSI.black.fg.light}╱{ANSI.default.fg}'
        blank_glyph_below  = f'{ANSI.black.fg.light}╲{ANSI.default.fg}'
        blank_glyph_half   = f'{ANSI.black.fg.light}╳{ANSI.default.fg}'
        blank_column_above = [blank_glyph_above] * M.math.floor(height / 2)
        blank_column_below = [blank_glyph_below] * M.math.floor(height / 2)
        blank_column_half  = [blank_glyph_half] if height % 2 else []
        blank_column       = blank_column_above + blank_column_half + blank_column_below

        for i in range(height):
            cell = space
            y    = height - i

            if load_percentage >= y:
                cell = f'{load.color.fg.light}{GLYPHS.heavy.ns}{ANSI.default.fg}'

            if temperature_percentage >= y:
                cell = f'{temperature.color.bg.dark}{cell}{ANSI.default.bg}'

            if cell == space:
                cell = blank_column[i]

            column.append(cell)

        with self._instance_lock:
            if self._fingerprint != fingerprint:
                self._cache       = []
                self._fingerprint = fingerprint

                for y in range(height):
                    cell = blank_column[y]
                    row  = [cell] * width
                    row  = M.collections.deque(row, maxlen=width)

                    self._cache.append(row)

            for y, row in enumerate(self._cache):
                row.append(column[y])
                output.append(empty.join(row))

        return M.os.linesep.join(output)




class Value(Window):
    _common_font     = False
    _common_label    = False
    _Value_instances = M.weakref.WeakSet()
    _Value_lock      = M.threading.RLock()


    @Window.height.setter
    def height(self, value, /):
        with __class__._Value_lock:
            Window.height.fset(self, value)

            if self in __class__._Value_instances:
                __class__._set_common_properties()


    @Window.title.setter
    def title(self, value, /):
        with __class__._Value_lock:
            Window.title.fset(self, value)

            if self in __class__._Value_instances:
                __class__._set_common_properties()


    @Window.width.setter
    def width(self, value, /):
        with __class__._Value_lock:
            Window.width.fset(self, value)

            if self in __class__._Value_instances:
                __class__._set_common_properties()


    def __init__(self, *args, **kwargs):
        super().__init__(*args, **kwargs)

        with __class__._Value_lock:
            __class__._Value_instances.add(self)
            __class__._set_common_properties()


    def _render(self, /, *, height, width):
        calc_ceil_padding  = lambda taken, total: max(M.math.ceil((total - taken) / 2), 0)
        calc_floor_padding = lambda taken, total: max(M.math.floor((total - taken) / 2), 0)
        cls                = self.__class__
        empty              = ''
        height             = eva.normalize_integer(height, minimum=self._minimum_height)
        output             = []
        space              = ' '
        value              = getattr(SNAPSHOT, cls.__name__.lower(), False)
        width              = eva.normalize_integer(width, minimum=self._minimum_width)

        with __class__._Value_lock:
            font  = __class__._common_font
            label = __class__._common_label
            title = self.title

        if not font or value is False or not hasattr(cls, '_precompile'):
            return
        else:
            precompiled = cls._precompile(value)

        for y in range(font.height):
            number = empty.join( font.glyphs.get(char, font.fallback)[y] for char in precompiled.align )
            affix  = empty.join( font.glyphs.get(char, font.fallback)[y] for char in precompiled.affix )
            line   = f'{precompiled.color.fg.dark}{number}{ANSI.dim.on}{affix}{ANSI.default.all}'

            output.append(line)

        taken  = len(precompiled.full) * font.width
        end    = space * calc_ceil_padding(taken, width)
        start  = space * calc_floor_padding(taken, width)
        output = [ f'{start}{line}{end}' for line in output ]

        if label:
            taken  = len(title)
            end    = space * calc_ceil_padding(taken, width)
            start  = space * calc_floor_padding(taken, width)
            output = [f'{start}{ANSI.dim.on}{title}{ANSI.dim.off}{end}'] + output

        taken  = len(output)
        filler = [space * width]
        end    = filler * (calc_floor_padding if BORDER else calc_ceil_padding)(taken, height)
        start  = filler * (calc_ceil_padding if BORDER else calc_floor_padding)(taken, height)
        output = start + output + end

        return M.os.linesep.join(output)


    @staticmethod
    def _set_common_properties():
        by_size   = lambda f: (f.height, f.width)
        fonts     = sorted(vars(FONTS).values(), key=by_size, reverse=True)
        max_value = max(len(precompile_load(None).full), len(precompile_temperature(None).full))

        with __class__._Value_lock:
            __class__._common_font  = False
            __class__._common_label = False

            instances = __class__._Value_instances

            max_title  = max( len(instance.title)   for instance in instances )
            min_height = min( instance.inner.height for instance in instances )
            min_width  = min( instance.inner.width  for instance in instances )

            for font in fonts:
                if font.height <= min_height and font.width * max_value <= min_width:
                    __class__._common_font = font

                    if not BORDER and max_title <= min_width and min_height > font.height:
                        __class__._common_label = all( instance.title for instance in instances )

                    break




