def target_snapshot():
    try:
        global SNAPSHOT

        by_thread = lambda cpu: cpu.thread
        chrono    = eva.Chrono(timeout=INTERVAL)
        maximum   = TEMPERATURE_MINIMUM
        minimum   = TEMPERATURE_MAXIMUM
        samples   = M.collections.deque()

        while True:
            chrono.reset()

            cpus        = []
            load        = eva.CPU.load
            temperature = eva.CPU.temperature
            maximum     = max(temperature, maximum) if BREATHER.expired else temperature
            minimum     = min(temperature, minimum)

            sample             = M.types.SimpleNamespace()
            sample.chrono      = eva.Chrono(timeout=TIMEOUT_SMOOTHED)
            sample.temperature = temperature

            while samples:
                if samples[0].chrono.expired:
                    samples.popleft()
                else:
                    break

            samples.append(sample)

            for cpu in eva.CPU.get_cpus(auto=True, online=True):
                sample = M.types.SimpleNamespace()

                for name in CPU_LAYOUT_FIELDS:
                    value = getattr(cpu, name)

                    setattr(sample, name, value)

                cpus.append(sample)

            cpus.sort(key=by_thread)

            snapshot          = M.types.SimpleNamespace()
            snapshot.cpus     = tuple(cpus)
            snapshot.load     = load
            snapshot.maximum  = maximum
            snapshot.minimum  = minimum
            snapshot.current  = temperature
            snapshot.smoothed = M.statistics.mean( sample.temperature for sample in samples )
            SNAPSHOT          = snapshot

            EVENTS.screen.set()

            if EVENTS.bye.wait(chrono.remaining):
                break
    finally:
        EVENTS.bye.set()




def target_stress():
    if STRESS:
        try:
            context = M.multiprocessing.get_context('spawn')
            tasks   = []

            def append_task(cpu, /):
                target  = target_stressor
                stop    = context.Event()
                args    = (cpu, stop)
                process = context.Process(args=args, daemon=False, target=target)
                task    = M.types.SimpleNamespace(cpu=cpu, process=process, stop=stop)

                tasks.append(task)
                process.start()

                with M.contextlib.suppress(OSError):
                    M.os.sched_setaffinity(process.pid, {task.cpu})

            def discard_task(task, /):
                task.stop.set()
                task.process.join()
                tasks.remove(task)

            while True:
                bye = EVENTS.bye.is_set()

                if bye or not EVENTS.stress.is_set():
                    for task in list(tasks):
                        discard_task(task)

                    if bye:
                        break
                    else:
                        EVENTS.stress.wait()

                for task in list(tasks):
                    try:
                        affinity = M.os.sched_getaffinity(task.process.pid)
                    except OSError:
                        affinity = None

                    if affinity != {task.cpu} or not task.process.is_alive():
                        append_task(task.cpu)
                        discard_task(task)

                cpus = set(eva.CPU.get_cpus(online=True)) - set( task.cpu for task in tasks )

                for cpu in cpus:
                    append_task(cpu)
        finally:
            EVENTS.bye.set()




