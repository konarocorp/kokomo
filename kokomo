class Box:
    _border_glyphs  = build_glyphs().arc
    _minimum_height = 0
    _minimum_width  = 0
    _minimum_x      = 1
    _minimum_y      = 1


    def _fget_height(self, /):
        return self._height


    def _fget_inner(self, /):
        with self._instance_lock:
            border = getattr(self, 'border', False)
            height = self.height
            width  = self.width

        if border:
            height = max(height - 2, 0) # 2 -> border + border
            width  = max(width  - 4, 0) # 4 -> border + space + space + border

        return M.types.SimpleNamespace(height=height, width=width)


    def _fget_width(self, /):
        return self._width


    def _fget_x(self, /):
        return self._x


    def _fget_y(self, /):
        return self._y


    def _fset_height(self, value, /):
        value = eva.normalize_integer(value, minimum=self._minimum_height)

        with self._instance_lock:
            self._height = value


    def _fset_width(self, value, /):
        value = eva.normalize_integer(value, minimum=self._minimum_width)

        with self._instance_lock:
            self._width = value


    def _fset_x(self, value, /):
        value = eva.normalize_integer(value, minimum=self._minimum_x)

        with self._instance_lock:
            self._x = value


    def _fset_y(self, value, /):
        value = eva.normalize_integer(value, minimum=self._minimum_y)

        with self._instance_lock:
            self._y = value


    height = property(fget=_fget_height, fset=_fset_height)
    inner  = property(fget=_fget_inner)
    width  = property(fget=_fget_width,  fset=_fset_width)
    x      = property(fget=_fget_x,      fset=_fset_x)
    y      = property(fget=_fget_y,      fset=_fset_y)


    def __init__(self, /, *, height=None, width=None, x=None, y=None):
        self._instance_lock = M.threading.RLock()

        self.height = self._minimum_height if height is None else height
        self.width  = self._minimum_width  if width  is None else width
        self.x      = self._minimum_x      if x      is None else x
        self.y      = self._minimum_y      if y      is None else y


    def _render(self, *args, **kwargs):
        return self._render_noise(*args, **kwargs)


    def _render_empty(self, /, *, height, width):
        height = eva.normalize_integer(height, minimum=self._minimum_height)
        space  = ' '
        width  = eva.normalize_integer(width, minimum=self._minimum_width)

        line  = space * width
        lines = [line] * height

        return M.os.linesep.join(lines)


    def _render_noise(self, /, *, height, width):
        empty  = ''
        glyphs = ('░', '▒', '█')
        height = eva.normalize_integer(height, minimum=self._minimum_height)
        output = []
        width  = eva.normalize_integer(width, minimum=self._minimum_width)

        for _ in range(height):
            line = empty.join( M.random.choice(glyphs) for _ in range(width) )

            output.append(line)

        return M.os.linesep.join(output)


    def show(self, /):
        blank         = f'{ANSI.blink.on}{ANSI.red.fg.dark}╳{ANSI.default.all}'
        empty         = ''
        fstr_position = '\x1B[{y};{x}H'
        output        = []
        space         = ' '

        with self._instance_lock:
            box        = M.types.SimpleNamespace()
            box.border = getattr(self, 'border', False)
            box.height = self.height
            box.title  = getattr(self, 'title', empty)
            box.width  = self.width
            box.x      = self.x
            box.y      = self.y
            inner      = self.inner

        if inner.height and inner.width:
            if isinstance(render := self._render(height=inner.height, width=inner.width), str):
                output = render.split(M.os.linesep)

                if len(output) < inner.height:
                    padding = [blank * inner.width] * max(inner.height - len(output), 0)
                    output  = output + padding
                else:
                    output = output[:inner.height]

                if box.border:
                    style_border_off = ANSI.dim.off
                    style_border_on  = ANSI.dim.on
                    style_title_off  = empty
                    style_title_on   = ANSI.default.fg

                    style_bottom = f'{style_border_on}{self._border_glyphs.ew}{style_border_off}'
                    style_end    = f'{style_border_on}{space}{self._border_glyphs.ns}{style_border_off}'
                    style_es     = f'{style_border_on}{self._border_glyphs.es}{style_border_off}'
                    style_ne     = f'{style_border_on}{self._border_glyphs.ne}{style_border_off}'
                    style_nw     = f'{style_border_on}{self._border_glyphs.nw}{style_border_off}'
                    style_start  = f'{style_border_on}{self._border_glyphs.ns}{space}{style_border_off}'
                    style_sw     = f'{style_border_on}{self._border_glyphs.sw}{style_border_off}'
                    style_top    = f'{style_border_on}{self._border_glyphs.ew}{style_border_off}'

                    bottom = style_bottom * (box.width - 2) # 2 -> corner + corner

                    if box.title:
                        title = box.title[:inner.width]
                        free  = inner.width - len(title)
                        end   = style_top * M.math.ceil(free / 2)
                        start = style_top * M.math.floor(free / 2)
                        top = f'{start}{space}{style_title_on}{title}{style_title_off}{space}{end}'
                    else:
                        top = style_top * (box.width - 2) # 2 -> corner + corner

                    bottom = f'{style_ne}{bottom}{style_nw}'
                    output = [ f'{style_start}{line}{style_end}' for line in output ]
                    top    = f'{style_es}{top}{style_sw}'
                    output = [top] + output + [bottom]

        if len(output) < box.height:
            padding = [blank * box.width] * max(box.height - len(output), 0)
            output  = output + padding
        else:
            output = output[:box.height]

        for i, line in enumerate(output):
            position  = fstr_position.format(x=box.x, y=box.y + i)
            output[i] = f'{position}{line}{ANSI.default.all}'

        TERMINAL.write(empty.join(output))




